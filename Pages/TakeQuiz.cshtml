@page "/Quiz/Take/{id:int}"
@model eExploreKL.Pages.TakeQuizModel
@{
    ViewData["Title"] = Model.Landmark.Name + " Quiz";
}

<style>
    /* Premium glassmorphic background layer matching the rest of the application */
    body {
        background: linear-gradient(135deg, rgba(10, 23, 42, 0.85), rgba(15, 41, 62, 0.92)), url('https://images.unsplash.com/photo-1596422846543-75c6fc18a52b?q=80&w=1600') no-repeat center center fixed !important;
        background-size: cover !important;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    /* Glassmorphic header banner */
    .quiz-head {
        position: relative;
        background: linear-gradient(135deg, rgba(22, 160, 133, 0.25), rgba(14, 102, 85, 0.45));
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff; 
        border-radius: 24px; 
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        overflow: hidden;
    }

    .quiz-head .eyebrow { 
        color: #2ecc71; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
        font-weight: 700; 
        font-size: .8rem; 
    }

    /* Glassmorphic frosted question container panels */
    .question-card { 
        background: rgba(255, 255, 255, 0.06) !important; 
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        border-radius: 20px !important; 
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25) !important;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: #fff;
        margin-bottom: 24px !important;
    }

    /* Floating vivid round counter index labels */
    .question-num {
        display: inline-flex; 
        align-items: center; 
        justify-content: center;
        width: 36px; 
        height: 36px; 
        border-radius: 50%;
        background: linear-gradient(135deg, #1abc9c, #16a085); 
        color: #fff; 
        font-weight: 800; 
        margin-right: 14px;
        box-shadow: 0 4px 10px rgba(22, 160, 133, 0.3);
    }

    /* Micro indicators for level difficulty scales */
    .difficulty { 
        font-size: .75rem; 
        font-weight: 700; 
        padding: 4px 12px; 
        border-radius: 999px; 
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .d-Easy   { background: rgba(46, 204, 113, 0.2); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.25); }
    .d-Medium { background: rgba(241, 196, 15, 0.2); color: #f1c40f; border: 1px solid rgba(241, 196, 15, 0.25); }
    .d-Hard   { background: rgba(231, 76, 60, 0.2); color: #e74c3c; border: 1px solid rgba(231, 76, 60, 0.25); }

    /* Frosted options selectors */
    .option {
        display: block; 
        border: 1px solid rgba(255, 255, 255, 0.08); 
        background: rgba(255, 255, 255, 0.03);
        border-radius: 14px;
        padding: 16px 20px; 
        margin-bottom: 12px; 
        cursor: pointer; 
        transition: all .2s cubic-bezier(0.25, 0.8, 0.25, 1);
        color: rgba(255, 255, 255, 0.9);
    }
    .option:hover { 
        border-color: rgba(243, 156, 18, 0.4); 
        background: rgba(255, 255, 255, 0.08); 
        transform: translateX(4px);
    }
    .option input { 
        margin-right: 12px; 
        accent-color: #f39c12;
    }
    .option:has(input:checked) { 
        border-color: #f39c12; 
        background: rgba(243, 156, 18, 0.12); 
        font-weight: 600; 
        color: #fff;
        box-shadow: 0 0 15px rgba(243, 156, 18, 0.15);
    }

    /* Functional UI Buttons */
    .btn-submit-custom {
        background: linear-gradient(135deg, #f1c40f, #f39c12);
        border: none;
        color: #0f172a !important;
        font-weight: 700;
        padding: 14px 32px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(243, 156, 18, 0.35);
        transition: all 0.2s ease;
    }
    .btn-submit-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(243, 156, 18, 0.5);
    }

    .btn-back-custom {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.7) !important;
        font-weight: 600;
        padding: 14px 28px;
        border-radius: 12px;
        transition: all 0.2s ease;
    }
    .btn-back-custom:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff !important;
    }

    .error-box-custom {
        background: rgba(231, 76, 60, 0.15);
        border: 1px solid rgba(231, 76, 60, 0.3);
        color: #e74c3c;
        border-radius: 14px;
        padding: 16px;
    }
</style>

<div class="container pt-5 mt-4" style="max-width: 950px; position: relative; z-index: 2;">
    <!-- Head Metadata Summary -->
    <div class="quiz-head mb-4">
        <p class="eyebrow mb-1">@Model.Landmark.Category Quiz</p>
        <h1 class="fw-bold mb-2 display-5" style="letter-spacing: -1px;">@Model.Landmark.Name</h1>
        <p class="mb-0 fs-5 text-white-50">@Model.Landmark.Description</p>
    </div>

    <!-- Active Submission Assessment Block -->
    <form method="post" id="quizForm" novalidate>
        @for (var i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];
            <div class="card question-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                        <h4 class="mb-0 d-flex align-items-center fw-bold lh-base">
                            <span class="question-num">@(i + 1)</span>@q.QuestionText
                        </h4>
                        <span class="difficulty d-@q.Difficulty">@q.Difficulty · @q.Points pts</span>
                    </div>

                    <input type="hidden" name="Answers[@i].QuestionId" value="@q.Id" />

                    <label class="option">
                        <input type="radio" name="Answers[@i].SelectedOption" value="A" /> @q.OptionA
                    </label>
                    <label class="option">
                        <input type="radio" name="Answers[@i].SelectedOption" value="B" /> @q.OptionB
                    </label>
                    <label class="option">
                        <input type="radio" name="Answers[@i].SelectedOption" value="C" /> @q.OptionC
                    </label>
                    <label class="option">
                        <input type="radio" name="Answers[@i].SelectedOption" value="D" /> @q.OptionD
                    </label>
                </div>
            </div>
        }

        <!-- Interactive Error Message Box -->
        <div id="quizError" class="error-box-custom fw-bold mb-4 text-center shadow" style="display:none;">
            ⚠️ Please answer every question before submitting.
        </div>

        <!-- Form Control Actions Layout -->
        <div class="d-flex gap-3 mb-5">
            <button type="submit" class="btn btn-submit-custom btn-lg px-5">Submit Answers</button>
            <a href="/Quiz" class="btn btn-back-custom btn-lg">Back to Quizzes</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('quizForm').addEventListener('submit', function (e) {
            var total = @Model.Questions.Count;
            var answered = new Set();
            document.querySelectorAll('input[type=radio]:checked').forEach(function (el) {
                answered.add(el.name);
            });
            if (answered.size < total) {
                e.preventDefault();
                document.getElementById('quizError').style.display = 'block';
                window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
            }
        });
    </script>
}