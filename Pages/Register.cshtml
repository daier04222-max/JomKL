@page "/Register"
@model JomKL.Pages.RegisterModel
@{
    ViewData["Title"] = "Learner Registration";
}

<style>
    /* Premium uniform glassmorphic backdrop canvas matching your design language */
    body {
        background: linear-gradient(135deg, rgba(10, 23, 42, 0.85), rgba(15, 41, 62, 0.92)), url('https://images.unsplash.com/photo-1596422846543-75c6fc18a52b?q=80&w=1600') no-repeat center center fixed !important;
        background-size: cover !important;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .auth-container {
        max-width: 460px;
        margin: 80px auto;
    }

    /* Upgraded deep frosted authentic panel structure */
    .glass-auth-card {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 24px;
        padding: 45px 40px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        color: #fff;
    }

    /* Translucent sleek form text entries */
    .form-control-custom {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        color: #fff !important;
        border-radius: 14px;
        padding: 14px 18px;
        transition: all 0.25s ease;
    }

    .form-control-custom:focus {
        border-color: #1abc9c !important;
        background: rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 0 0 4px rgba(26, 188, 156, 0.2) !important;
        outline: none;
    }

    /* Premium dynamic confirmation system button actions */
    .btn-submit-custom {
        background: linear-gradient(135deg, #1abc9c, #16a085);
        border: none;
        color: #fff;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 14px;
        border-radius: 14px;
        box-shadow: 0 6px 20px rgba(22, 160, 133, 0.35);
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .btn-submit-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(22, 160, 133, 0.5);
    }
    
    .btn-submit-custom:active {
        transform: translateY(0);
    }

    /* Frosted warning validation output box */
    .error-box {
        background: rgba(231, 76, 60, 0.15);
        border: 1px solid rgba(231, 76, 60, 0.25);
        color: #e74c3c;
        border-radius: 14px;
        padding: 14px;
        font-size: 0.9rem;
    }
    
    .input-label-custom {
        font-size: 0.78rem;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.6);
    }
</style>

<div class="container auth-container">
    <div class="glass-auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-white mb-2" style="letter-spacing: -0.5px;">Create Account</h2>
            <p class="text-white-50 small mb-0">Kuala Lumpur Landmark Discovery - Registration</p>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="error-box mb-4 text-center shadow-sm">
                ⚠️ @TempData["Message"]
            </div>
        }

        <form id="registerForm" method="post" onsubmit="return validateRegisterForm()" novalidate>
            <div class="mb-3">
                <label for="fullName" class="form-label input-label-custom fw-bold mb-2">Full Name</label>
                <input type="text" id="fullName" name="fullName" class="form-control form-control-custom" placeholder="John Doe" required />
            </div>

            <div class="mb-3">
                <label class="form-label input-label-custom fw-bold mb-2">Email Address</label>
                <input type="email" id="email" name="email" class="form-control form-control-custom" placeholder="name@example.com" required />
            </div>

            <div class="mb-4">
                <label class="form-label input-label-custom fw-bold mb-2">Password</label>
                <input type="password" id="password" name="password" class="form-control form-control-custom" placeholder="••••••••" required />
                <div id="passwordError" class="text-danger small mt-2 fw-bold"></div>
            </div>

            <button type="submit" class="btn btn-submit-custom w-100 mb-2">Register Account</button>
        </form>

        <div class="text-center mt-4">
            <p class="mb-0 text-white-50 small">Already have an account? <a href="/Login" class="text-info fw-bold text-decoration-none" style="transition: color 0.2s; color: #1abc9c !important;">Login here</a></p>
        </div>
    </div>
</div>

<script>
function validateRegisterForm() {
    document.getElementById("passwordError").innerText = "";
    var password = document.getElementById("password").value;

    if (password.length < 6) {
        document.getElementById("passwordError").innerText = "⚠️ Password must be at least 6 characters long.";
        return false;
    }
    return true;
}
</script>