@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<style>
    html {
        scroll-behavior: smooth;
    }
    
    body {
        background-image: url('/images/kl-hero.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        overflow-x: hidden;
    }

    .scroll-section {
        min-height: 100vh; 
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
    }

    .content-box {
        background-color: rgba(0, 0, 0, 0.7);
        padding: 60px 80px;
        border-radius: 20px;
        text-align: center;
        width: 90%;
        max-width: 1200px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    }

    .content-box-animated, .about-title, .about-text {
        opacity: 0;
        transform: translateY(20px);
        transition: all 1.2s ease-out;
    }

    .content-box-animated.show {
        opacity: 1;
        transform: translateY(0);
    }

    .about-title.show {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.3s;
    }

    .about-text.show {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.6s;
    }

    .back-to-top {
        position: fixed;
        bottom: 40px;
        right: 40px;
        background-color: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(5px);
        color: white;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        text-align: center;
        line-height: 46px;
        font-size: 26px;
        font-weight: 900;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        z-index: 1000;
        transition: all 0.3s ease;
    }
    
    .back-to-top:hover {
        transform: scale(1.1);
        background-color: rgba(0, 0, 0, 0.9);
        color: white;
    }

    .btn-jomkl-premium {
        background-color: rgba(0, 0, 0, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        animation: premiumPulse 2s infinite;
    }
    
    .btn-jomkl-premium:hover {
        background-color: rgba(255, 255, 255, 0.9);
        color: black;
        border: 1px solid black;
        transform: scale(1.05);
        animation: none; 
        
        box-shadow: 0 5px 15px rgba(255, 255, 255, 0.4);
    }

    /* 3D Box */
    #tilt-box {
        perspective: 1000px; 
        transform-style: preserve-3d;
    }

    #tilt-box.reset-tilt {
        transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    /* Carousel Indicator */
    .carousel-indicators {
        bottom: -50px;
    }
    
    .carousel-indicators [data-bs-target] {
        width: 12px !important;
        height: 12px !important;
        border-radius: 50% !important;
        background-color: #dcdde1 !important;
        margin: 0 6px !important;
        border: none !important;
        opacity: 0.5 !important;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    }
    
    .carousel-indicators .active {
        width: 38px !important;
        border-radius: 10px !important;
        background-color: #FF9800 !important;
        opacity: 1 !important;
    }

    /* Click Effect */
    .firework-particle {
        position: fixed;
        top: 0; 
        left: 0;
        width: 8px;            
        height: 8px;
        background-color: #FF9800;
        border-radius: 50%;   
        pointer-events: none;
        z-index: 9999;  
    }

    /* Core Function Introduction Grid Style */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 40px;
        text-align: left;
        margin-top: 40px;
    }
    
    .feature-item {
        padding: 30px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 15px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.3s ease, background 0.3s ease;
    }
    
    .feature-item:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.08);
    }
    
    .feature-icon {
        margin-bottom: 20px;
    }
    
    .feature-item h3 {
        color: white;
        font-size: 1.4rem;
        font-weight: bold;
        margin-bottom: 15px;
    }
    
    .feature-item p {
        color: #dcdde1;
        font-size: 1rem;
        line-height: 1.6;
    }

    @@media (max-width: 768px) {
        .features-grid {
            grid-template-columns: 1fr;
        }
    }

    /* The button's orange radar breathing halo animation */
    @@keyframes premiumPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.7);
        }
        70% {
            box-shadow: 0 0 0 15px rgba(255, 152, 0, 0); 
        }
        100% {
            box-shadow: 0 0 0 0 rgba(255, 152, 0, 0); 
        }
    }
</style>

<div id="page-top"></div>

