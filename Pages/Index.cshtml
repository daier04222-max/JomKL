<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>

<script>
        // section 1 Text separation effect
        window.addEventListener('scroll', function() {
            let scrollY = window.scrollY; 
            let textLeft = document.getElementById('text-left');
            let textRight = document.getElementById('text-right');

            if (textLeft && textRight) {
                let moveSpeed = scrollY * 1.5; 
                let opacitySpeed = 1 - (scrollY / 260); 

                textLeft.style.transform = `translateX(-${moveSpeed}px)`;
                textLeft.style.opacity = opacitySpeed;

                textRight.style.transform = `translateX(${moveSpeed}px)`;
                textRight.style.opacity = opacitySpeed;
            }
        });

        // section 2 Fade-in effect
        document.addEventListener("DOMContentLoaded", function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('show');
                    } else {
                        entry.target.classList.remove('show');
                    }
                });
            }, {
                threshold: 0.2
            });

            document.querySelectorAll('.content-box-animated, .about-title, .about-text').forEach(el => {
                observer.observe(el);
            });
        });

        // section 3 3D effect
        const tiltBox = document.getElementById('tilt-box');
        
        if (tiltBox) {
            tiltBox.addEventListener('mousemove', (e) => {
                tiltBox.classList.remove('reset-tilt');

                const rect = tiltBox.getBoundingClientRect();
                
                const x = e.clientX - rect.left; 
                const y = e.clientY - rect.top;  

                const centerX = rect.width / 2;
                const centerY = rect.height / 2;

                const rotateX = ((y - centerY) / centerY) * -10;
                const rotateY = ((x - centerX) / centerX) * 10;

                tiltBox.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            });

            tiltBox.addEventListener('mouseleave', () => {
                tiltBox.classList.add('reset-tilt');
                tiltBox.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
            });
        }

        // Mouse click effect 
        document.addEventListener('click', function(e) {
            const numParticles = 15; 
            const particles = [];

            for (let i = 0; i < numParticles; i++) {
                let p = document.createElement('div');
                p.classList.add('firework-particle');
                p.style.left = e.clientX + 'px';
                p.style.top = e.clientY + 'px';
                document.body.appendChild(p);
                particles.push(p);
            }

            anime({
                targets: particles,
                translateX: function() { return anime.random(-100, 100); },
                translateY: function() { return anime.random(-100, 100); },
                scale: [1, 0],    
                opacity: [1, 0],  
                easing: 'easeOutExpo', 
                duration: anime.random(1500, 2000), 
                complete: function(anim) {
                    particles.forEach(p => p.remove());
                }
            });
        });
</script>

