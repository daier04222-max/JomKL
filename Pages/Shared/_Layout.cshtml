<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Interactive Cultural & Landmark Discovery</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Titan+One&display=swap');
        .active-page {
            background-color: #ffffff; 
            color: #212529 !important; 
            border-radius: 20px;
            font-weight: bold;
            padding-left: 18px !important;
            padding-right: 18px !important;
            box-shadow: 0 4px 15px rgba(255, 255, 255, 0.3); 
            transition: all 0.3s ease;
        }
    
        .nav-link:hover:not(.active-page) {
            text-shadow: 0 0 8px rgba(255,255,255,0.8);
        }

        @@keyframes bounce-up-down {
            0%, 100% { 
                transform: translateY(0); 
            }
            50% { 
                transform: translateY(-12px);
            }
        }

        .btn-back-to-top {
            position: fixed;
            bottom: 40px;           
            right: 40px;            
            width: 55px;
            height: 55px;
            background-color: #ffffff;  
            
            color: #000000 !important;             
            
            border-radius: 50%;         
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            
            font-weight: 1500 !important;
            -webkit-text-stroke: 3px black; 
            
            text-decoration: none !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2); 
            z-index: 1000;              
            animation: bounce-up-down 2s infinite ease-in-out; 
            transition: background-color 0.3s ease;
        }

        .btn-back-to-top:hover {
            background-color: #e2e2e2;  
            color: #000000 !important;
            animation-play-state: paused; 
        }

        /* The state after the navigation bar scrolls */
        .wrapper-scrolled {
            padding-top: 10px !important; 
        }
        
        .nav-scrolled {
            background-color: #000000 !important; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.8) !important; 
        }
    </style>
    <link rel="stylesheet" href="~/eExploreKL.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div id="nav-wrapper" style="padding-top: 25px; display: flex; justify-content: center; position: fixed; top: 0; width: 100%; z-index: 1030; transition: padding-top 0.4s ease;">
            <nav id="main-navbar" class="navbar navbar-expand-sm navbar-toggleable-sm" style="background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(10px); border-radius: 50px; width: 85%; padding: 10px 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: background-color 0.4s ease, box-shadow 0.4s ease;">
                <div class="container-fluid p-0">
                    <a class="navbar-brand" style="color: white; font-size: 1.8rem; font-family: 'Titan One', cursive; letter-spacing: 2px;" asp-area="" asp-page="/Index">
                        Jom<span style="color: #FF9800;">KL!</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <ul class="navbar-nav">
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active-page" : "")" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/About" ? "active-page" : "")" asp-page="/About">About Us</a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/Map" ? "active-page" : "")" asp-page="/Map">KL Map</a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/Dashboard" ? "active-page" : "")" asp-page="/Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/Login" ? "active-page" : "")" asp-page="/Login">Login</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-white" style="background-color: rgba(0, 0, 0, 0.4); border: none;">
        <div class="container">
            &copy; 2026 - JomKL! - <a asp-area="" asp-page="/Privacy" class="text-white">Privacy</a>
        </div>
    </footer>

    <a href="#" class="btn-back-to-top" title="Back to Top">
        ↑
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        window.addEventListener('scroll', function() {
            var navWrapper = document.getElementById('nav-wrapper');
            var mainNavbar = document.getElementById('main-navbar');
            
            if (window.scrollY > 50) {
                navWrapper.classList.add('wrapper-scrolled');
                mainNavbar.classList.add('nav-scrolled');
            } else {
                navWrapper.classList.remove('wrapper-scrolled');
                mainNavbar.classList.remove('nav-scrolled');
            }
        });
    </script>
</body>
</html>