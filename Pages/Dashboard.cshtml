@page

<style>
    /* Global glassmorphic canvas setup */
    body {
        background: linear-gradient(135deg, rgba(10, 23, 42, 0.88), rgba(15, 41, 62, 0.94)), 
                    url('https://images.unsplash.com/photo-1596422846543-75c6fc18a52b?q=80&w=1600') no-repeat center center fixed !important;
        background-size: cover !important;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        color: #ffffff;
    }

    /* Converts your existing light dashboard and quiz panels into sleek frosted glass panels */
    .card, 
    .main-content panel, 
    div[class*="card"], 
    .bg-white,
    #registerForm,
    form {
        background: rgba(255, 255, 255, 0.06) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        backdrop-filter: blur(16px) !important;
        -webkit-backdrop-filter: blur(16px) !important;
        color: #ffffff !important;
        border-radius: 16px !important;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25) !important;
    }

    /* Standardizes textual descriptions, subtle labels, and muted text across layouts */
    .text-muted, 
    .text-black-50, 
    .text-white-50, 
    p.small, 
    label {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    /* Restores text visibility inside headers and body titles */
    h1, h2, h3, h4, h5, h6, .card-title {
        color: #ffffff !important;
    }

    /* Upgrades standard plain form entry inputs to match the registration scheme */
    .form-control {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #ffffff !important;
        border-radius: 10px !important;
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 0.08) !important;
        border-color: #1abc9c !important;
        box-shadow: 0 0 0 3px rgba(26, 188, 156, 0.25) !important;
        color: #ffffff !important;
    }
</style>

@model DashboardModel
@{
    ViewData["Title"] = "Dashboard - My Learning Progress";
}

<div class="container" style="padding-top: 120px;">
    <h2>📚 My Learning Center</h2>
    <p class="text-muted">Track your progress in exploring Kuala Lumpur's culture and landmarks</p>

    <hr />

    <!-- User Info Area -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 40px; color: white;">
                        👤
                    </div>
                    <div class="ms-3">
                        <h4 class="mb-0">@Model.UserName</h4>
                        <small class="text-muted">Member since @Model.JoinDate</small>
                    </div>
                    <div class="ms-auto text-end">
                        <span class="badge bg-primary fs-6">⭐ @Model.TotalScore pts</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card text-center bg-light">
                <div class="card-body">
                    <h6 class="card-title text-muted">📍 Landmarks</h6>
                    <p class="card-text fs-3 fw-bold text-primary">@Model.UnlockedLandmarks / @Model.TotalLandmarks</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center bg-light">
                <div class="card-body">
                    <h6 class="card-title text-muted">📝 Quizzes</h6>
                    <p class="card-text fs-3 fw-bold text-success">@Model.CompletedQuizzes / @Model.TotalQuizzes</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center bg-light">
                <div class="card-body">
                    <h6 class="card-title text-muted">🏅 Badges</h6>
                    <p class="card-text fs-3 fw-bold text-warning">@Model.BadgeCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card text-center bg-light">
                <div class="card-body">
                    <h6 class="card-title text-muted">📊 Completion</h6>
                    <p class="card-text fs-3 fw-bold text-info">@Model.CompletionRate%</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Bar -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Exploration Progress</h5>
                    <div class="progress" style="height: 30px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                             role="progressbar" 
                             style="width: @Model.CompletionRate%;" 
                             aria-valuenow="@Model.CompletionRate" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
                            @Model.CompletionRate%
                        </div>
                    </div>
                    <small class="text-muted mt-2 d-block">
                        @Model.UnlockedLandmarks / @Model.TotalLandmarks landmarks unlocked
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Badge Collection -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🏅 My Badges</h5>
                    @if (Model.Badges.Any())
                    {
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var badge in Model.Badges)
                            {
                                <div class="text-center" style="width: 100px;">
                                    <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center mx-auto" style="width: 64px; height: 64px; font-size: 30px;">
                                        🏅
                                    </div>
                                    <small class="d-block text-muted mt-1">@badge.Name</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No badges earned yet. Keep exploring! 🚀</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>