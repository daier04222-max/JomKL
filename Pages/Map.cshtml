@page
@model eExploreKL.Pages.MapModel
@{
    ViewData["Title"] = "Interactive KL Map";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<style>
    #kl-interactive-map { 
        height: 70vh; 
        min-height: 400px;
        width: 100%; 
        border-radius: 12px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 1; 
    }
    
    .landmark-info-layer { padding: 10px; text-align: center; }
    .landmark-info-layer h3 { margin-top: 0; color: #2c3e50; font-size: 1.2rem; }
    .landmark-info-layer p { font-size: 0.95rem; color: #555; text-align: justify; }
    .audio-player { width: 100%; margin-top: 15px; outline: none; }
</style>

<div class="container mt-4">
    <h2 class="mb-3 text-center">Explore Kuala Lumpur</h2>
    <p class="text-center text-muted mb-4">Click on any landmark icon on the map to discover its history and listen to the audio guide.</p>
    
    <div id="kl-interactive-map"></div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var map = L.map('kl-interactive-map').setView([3.1390, 101.6869], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        var landmarksData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Landmarks));

        landmarksData.forEach(function (landmark) {
            if (landmark.Latitude && landmark.Longitude) {
                var marker = L.marker([landmark.Latitude, landmark.Longitude]).addTo(map);

                var popupHtml = '<div class="landmark-info-layer">';
                popupHtml += '<h3>' + landmark.Name + '</h3>';
                
                if (landmark.Description) {
                    popupHtml += '<p>' + landmark.Description + '</p>';
                }
                
                if (landmark.AudioUrl) {
                    popupHtml += '<audio controls class="audio-player">';
                    popupHtml += '<source src="' + landmark.AudioUrl + '" type="audio/mpeg">';
                    popupHtml += '</audio>';
                }
                
                popupHtml += '</div>';

                marker.bindPopup(popupHtml);
            }
        });
    });
</script>