@page
@model YourProjectName.Pages.MapModel 
@{
    ViewData["Title"] = "Kuala Lumpur Documentary Map";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<style>
    #map {
        width: 100%;
        height: 85vh; 
        border-radius: 8px; 
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .custom-popup h3 {
        margin: 0 0 5px 0;
        color: #2c3e50;
        font-size: 16px;
        font-weight: bold;
    }
    .custom-popup strong {
        display: block;
        color: #7f8c8d;
        font-size: 12px;
        margin-bottom: 8px;
    }
    .custom-popup p {
        margin: 0;
        color: #34495e;
        font-size: 14px;
        line-height: 1.5;
    }
</style>

<h2>Documentary Locations Map</h2>
<p>Click on the blue markers to view details about each location.</p>

<div id="map"></div>

<script>
    var map = L.map('map').setView([3.1390, 101.6869], 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    var attractions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Attractions));

    attractions.forEach(function(place) {
        var marker = L.marker([place.Lat, place.Lng]).addTo(map);
        
        var popupContent = `
            <div class="custom-popup">
                <h3>${place.Name}</h3>
                <strong>${place.Subtitle}</strong>
                <p>${place.Description}</p>
            </div>
        `;
        
        marker.bindPopup(popupContent);
    });
</script>