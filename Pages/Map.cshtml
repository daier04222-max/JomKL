@page "/Map"
@model eExploreKL.Pages.MapModel
@{
    ViewData["Title"] = "Explore Kuala Lumpur";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<style>
    .map-head {
        background: linear-gradient(135deg,#16a085,#0e6655);
        color:#fff; border-radius:20px; padding:32px 40px;
        box-shadow:0 8px 32px rgba(0,0,0,.25);
    }
    #kl-interactive-map { 
        height: 60vh; 
        min-height: 400px;
        width: 100%; 
        border-radius: 14px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 1; 
    }
    .lm-row {
        display:flex; align-items:center; gap:16px;
        background:#fff; border-radius:14px; padding:16px 20px;
        box-shadow:0 4px 14px rgba(0,0,0,.07); margin-bottom:12px;
    }
    .lm-pin {
        flex:0 0 48px; width:48px; height:48px; border-radius:50%;
        display:flex; align-items:center; justify-content:center;
        font-size:1.5rem; color:#fff; background:#16a085;
    }
    .lm-body { flex:1 1 auto; }
    .lm-body h6 { margin:0; font-weight:700; }
    .landmark-info-layer { padding: 10px; text-align: center; }
    .landmark-info-layer h3 { margin-top: 0; color: #2c3e50; font-size: 1.2rem; }
    .landmark-info-layer p { font-size: 0.95rem; color: #555; text-align: justify; }
    .audio-player { width: 100%; margin-top: 15px; outline: none; }
</style>

<div class="container pt-5 mt-5" style="max-width: 900px;">
    <div class="map-head mb-4">
        <h1 class="fw-bold mb-1">Explore Kuala Lumpur</h1>
        <p class="mb-0" style="opacity:.9;">
            Ten landmarks across the city. Interact with the map or select from the list below to learn and test your knowledge.
        </p>
    </div>

    <div class="mb-5">
        <div id="kl-interactive-map"></div>
    </div>

    <h3 class="fw-bold mb-3 text-secondary">Landmarks List</h3>
    @foreach (var lm in Model.Landmarks)
    {
        <div class="lm-row">
            <div class="lm-pin">📍</div>
            <div class="lm-body">
                <h6>@lm.Name <span class="text-muted small">· @lm.Category</span></h6>
                <div class="text-muted small">@lm.Description</div>
            </div>
            @if (lm.QuestionCount > 0)
            {
                <a class="btn btn-sm btn-warning fw-bold" asp-page="/TakeQuiz" asp-route-id="@lm.LandmarkId">Quiz</a>
            }
            else
            {
                <span class="badge bg-light text-muted">No quiz yet</span>
            }
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var map = L.map('kl-interactive-map').setView([3.1390, 101.6869], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        var landmarksData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Landmarks));

        landmarksData.forEach(function (landmark) {
            if (landmark.Latitude && landmark.Longitude) {
                var marker = L.marker([landmark.Latitude, landmark.Longitude]).addTo(map);

                var popupHtml = '<div class="landmark-info-layer">';
                popupHtml += '<h3>' + landmark.Name + '</h3>';
                
                if (landmark.Description) {
                    popupHtml += '<p>' + landmark.Description + '</p>';
                }
                
                if (landmark.AudioUrl) {
                    popupHtml += '<audio controls class="audio-player">';
                    popupHtml += '<source src="' + landmark.AudioUrl + '" type="audio/mpeg">';
                    popupHtml += '</audio>';
                }
                
                popupHtml += '</div>';

                marker.bindPopup(popupHtml);
            }
        });
    });
</script>