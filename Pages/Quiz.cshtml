@page "/Quiz"
@model eExploreKL.Pages.QuizModel
@{
    ViewData["Title"] = "Landmark Quizzes";
}

<style>
    .quiz-hero {
        background: linear-gradient(135deg, #212529 0%, #343a40 100%);
        color: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    }
    .quiz-hero h1 { font-weight: 800; }
    .quiz-hero .accent { color: #FF9800; }

    .quiz-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 6px 20px rgba(0,0,0,0.10);
        transition: transform .25s ease, box-shadow .25s ease;
        height: 100%;
    }
    .quiz-card:hover { transform: translateY(-6px); box-shadow: 0 14px 30px rgba(0,0,0,0.18); }

    .quiz-card-top {
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 2.6rem;
    }
    .cat-Landmark    { background: linear-gradient(135deg,#FF9800,#F57C00); }
    .cat-Cultural    { background: linear-gradient(135deg,#8e44ad,#6c3483); }
    .cat-Historical  { background: linear-gradient(135deg,#c0392b,#922b21); }
    .cat-Nature      { background: linear-gradient(135deg,#16a085,#0e6655); }
    .cat-Food        { background: linear-gradient(135deg,#e67e22,#ca6f1e); }
    .cat-Entertainment { background: linear-gradient(135deg,#2980b9,#1f618d); }
    .cat-default     { background: linear-gradient(135deg,#34495e,#2c3e50); }

    .tag-pill {
        display: inline-block;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 999px;
        background: #f1f3f5;
        color: #495057;
    }
    .best-badge { color: #198754; font-weight: 700; }
</style>

<div class="container pt-5 mt-5">
    <div class="quiz-hero mb-4">
        <h1>Kuala Lumpur landmark <span class="accent">quizzes</span></h1>
        <p class="mb-0 lead" style="opacity:.9;">
            Each quiz focuses on one KL landmark. Answer the questions to earn points and
            unlock the landmark on your dashboard.
        </p>
    </div>

    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning">
            You can browse the quizzes below, but you'll need to
            <a href="/Login" class="fw-bold">log in</a> to take one and save your score.
        </div>
    }

    <div class="row g-4">
        @foreach (var lm in Model.Landmarks)
        {
            var catClass = "cat-" + (string.IsNullOrEmpty(lm.Category) ? "default" : lm.Category);
            var icon = lm.Category switch
            {
                "Landmark" => "🏙️",
                "Cultural" => "🛕",
                "Historical" => "🏛️",
                "Nature" => "🌳",
                "Food" => "🍜",
                "Entertainment" => "🐠",
                _ => "📍"
            };
            <div class="col-sm-6 col-lg-4">
                <div class="card quiz-card">
                    <div class="quiz-card-top @catClass">@icon</div>
                    <div class="card-body d-flex flex-column">
                        <span class="tag-pill mb-2">@lm.Category</span>
                        <h5 class="card-title fw-bold">@lm.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@lm.Description</p>

                        @if (lm.QuestionCount > 0)
                        {
                            <ul class="list-unstyled small text-muted mb-3">
                                <li>📝 @lm.QuestionCount questions</li>
                                <li>⭐ @lm.TotalPoints pts available</li>
                                @if (lm.BestScore.HasValue)
                                {
                                    <li class="best-badge">🏅 Best: @lm.BestScore pts</li>
                                }
                            </ul>
                            <a class="btn @(lm.Completed ? "btn-outline-dark" : "btn-warning") fw-bold w-100"
                               asp-page="/TakeQuiz" asp-route-id="@lm.LandmarkId">
                                @(lm.Completed ? "Retake quiz" : "Start quiz")
                            </a>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted mb-3 align-self-start">Quiz coming soon</span>
                            <button class="btn btn-light w-100" disabled>Not available yet</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
